# ── Environment & secrets ─────────────────────────────────────────────────
.env
*.env.local

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover
.hypothesis/

# ── Node / Electron ───────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/dist-electron/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

