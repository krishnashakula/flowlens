# ─────────────────────────────────────────────────────────
# FlowLens — Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────

# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional (have defaults) ──────────────────────────────

# Redis connection URL (docker-compose sets this automatically)
REDIS_URL=redis://localhost:6379/0

# Server port
PORT=8000

# Enable hot-reload and verbose logging (development only)
DEBUG=false

# ── GCP Deployment ────────────────────────────────────────

# Your Google Cloud project ID
GCP_PROJECT_ID=your-gcp-project-id

# GCP region (must match Terraform variables)
GCP_REGION=us-central1

# Cloud Run service URL (set after first `make deploy`)
CLOUD_RUN_URL=https://flowlens-backend-xxxxxxxxxx-uc.a.run.app

# ── Frontend ─────────────────────────────────────────────

# WebSocket backend URL (used by Vite/Electron renderer)
VITE_WS_URL=ws://localhost:8000
